# 数据库（与 docker-compose 中用户/库名一致）
DATABASE_URL=postgres://deployhub:deployhub@localhost:5432/deployhub?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT 签名密钥（生产环境务必更换为强随机值）
JWT_SECRET=your-jwt-secret-change-in-production

# AES-256-GCM 加密密钥：32 字节，64 位十六进制（请自行生成并保密）
AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# OAuth（可选）
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# S3 兼容对象存储（头像上传等）
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=deployhub
S3_REGION=us-east-1

# Helm 环境 values 映射（cluster.env → values 文件后缀）
ENV_VALUES_MAP=qanet:qa,testnet:testnet,mainnet:mainnet

# Helm Runner Job 运行的命名空间（与服务命名空间分离）
HELM_JOB_NAMESPACE=deployhub-jobs

# 服务
SERVER_PORT=8080
LOG_LEVEL=debug
